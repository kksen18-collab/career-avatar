# Career Avatar Environment Configuration
# 
# THIS IS AN EXAMPLE FILE - It will NOT be read by Pydantic
# Copy this file to .env and fill in your actual values
# Only the .env file (without .example) is loaded by the application
# DO NOT commit the .env file to git - it contains sensitive keys

# OpenAI Configuration
# Get your API key from https://platform.openai.com/api-keys
# Must start with 'sk-'
OPENAI_API_KEY=sk-your-openai-api-key-here

# Pushover Notification Configuration
# Get these from https://pushover.net
# User key is your personal account identifier
PUSHOVER_USER_KEY=your-pushover-user-key-here

# Pushover API token for your application
PUSHOVER_API_TOKEN=your-pushover-api-token-here

# Pushover API endpoint (usually doesn't need to change)
PUSHOVER_URL=https://api.pushover.net/1/messages.json

# Your Profile Information
# This is used in system prompts to represent you as the Avatar
NAME=Your Full Name

# OpenAI Model Selection (optional)
# Default: gpt-4o-mini
# Other options: gpt-4o, gpt-4-turbo
MODEL=gpt-4o-mini

# Data File Paths (optional)
# Paths to your LinkedIn PDF and career summary
# Default: career_avatar/data/linkedin.pdf
LINKEDIN_PDF_PATH=career_avatar/data/linkedin.pdf

# Default: career_avatar/data/summary.txt
SUMMARY_PATH=career_avatar/data/summary.txt

# Setup Instructions:
# 1. Rename this file from .env.example to .env
# 2. Fill in your actual OpenAI API key
# 3. Fill in your Pushover credentials
# 4. Replace "Your Full Name" with your actual name
# 5. Keep the .env file in career_avatar/ directory
# 6. Never commit the .env file (it's in .gitignore)
